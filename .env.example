# LLM API配置（支持 OpenAI SDK 格式的任意 LLM API）
# 推荐使用阿里百炼平台qwen-plus模型：https://bailian.console.aliyun.com/
# 注意消耗较大，可先进行小于40轮的模拟尝试
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== ZEP记忆图谱配置 =====
# 每月免费额度即可支撑简单使用：https://app.getzep.com/
AMS_ENABLED=true
AMS_BASE_URL=http://localhost:8000
AMS_API_KEY=
AMS_TIMEOUT=30
AMS_GENERATION_MODEL=gpt-4o-mini
AMS_EMBEDDING_MODEL=text-embedding-3-small

# ===== Optional tuning =====
# FLASK_DEBUG=True
# FLASK_HOST=0.0.0.0
# FLASK_PORT=5001
# OASIS_DEFAULT_MAX_ROUNDS=10
# REPORT_AGENT_MAX_TOOL_CALLS=5
# REPORT_AGENT_MAX_REFLECTION_ROUNDS=2
# REPORT_AGENT_TEMPERATURE=0.5

# ===== Boost LLM (optional) =====
# LLM_BOOST_API_KEY=your_api_key_here
# LLM_BOOST_BASE_URL=your_base_url_here
# LLM_BOOST_MODEL_NAME=your_model_name_here

# ===== The Token Company — prompt compression (optional) =====
# Reduces LLM token usage by 10-40% by compressing prompts before each LLM call.
# Get an API key at https://thetokencompany.com
# TOKEN_COMPANY_ENABLED=false
# TOKEN_COMPANY_API_KEY=ttc-...
# TOKEN_COMPANY_MIN_CHARS=2000   # skip compression for short prompts

# ===== Browserbase / Stagehand — agent web tools (optional) =====
# Gives the report agent real web browsing capabilities (act/extract/observe).
# Get credentials at https://browserbase.com
# BROWSERBASE_ENABLED=false
# BROWSERBASE_API_KEY=
# BROWSERBASE_PROJECT_ID=

# ===== Sentry — error monitoring & performance tracing (optional) =====
# Auto-captures unhandled exceptions and traces agent/LLM call performance.
# Get a DSN at https://sentry.io
# SENTRY_DSN=
# SENTRY_TRACES_SAMPLE_RATE=0.2   # fraction of transactions to trace (0.0–1.0)
# SENTRY_ENVIRONMENT=development
# ===== 加速 LLM 配置（可选）=====
# 注意如果不使用加速配置，env文件中就不要出现下面的配置项
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here
